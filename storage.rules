rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function adminProfilePath() {
      return /databases/(default)/documents/userProfiles/$(request.auth.uid);
    }

    function isAdmin() {
      return signedIn()
        && exists(adminProfilePath())
        && get(adminProfilePath()).data.role == 'admin';
    }

    match /company-signatures/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
