[debug] [2026-04-02T22:11:17.077Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/halbmann-app/rulesets {"name":"projects/halbmann-app/rulesets/f120e0c2-3b5a-4710-8b96-5e63c78fdf77","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function isOwnProfile(userId) {\n      return signedIn() && request.auth.uid == userId;\n    }\n\n    function adminProfilePath() {\n      return /databases/$(database)/documents/userProfiles/$(request.auth.uid);\n    }\n\n    function isAdminFromAnotherProfile(targetUserId) {\n      return signedIn()\n        && request.auth.uid != targetUserId\n        && exists(adminProfilePath())\n        && get(adminProfilePath()).data.role == 'admin';\n    }\n\n    function isAdmin() {\n      return signedIn()\n        && exists(adminProfilePath())\n        && get(adminProfilePath()).data.role == 'admin';\n    }\n\n    function isTenant() {\n      return signedIn()\n        && exists(adminProfilePath())\n        && get(adminProfilePath()).data.role == 'tenant';\n    }\n\n    function authEmail() {\n      return signedIn() && request.auth.token.email is string\n        ? request.auth.token.email\n        : '';\n    }\n\n    function ownTenantDocById(tenantId) {\n      return tenantId is string\n        && tenantId != ''\n        && signedIn()\n        && exists(/databases/$(database)/documents/tenants/$(tenantId))\n        && get(/databases/$(database)/documents/tenants/$(tenantId)).data.email == authEmail();\n    }\n\n    function tenantOwnsMessage(data) {\n      return signedIn()\n        && (\n          (data.tenantId is string && ownTenantDocById(data.tenantId))\n          || (data.fromEmail is string && data.fromEmail == authEmail())\n        );\n    }\n\n    function tenantCanCreateMessage() {\n      return isTenant()\n        && request.resource.data.channel == 'portal'\n        && request.resource.data.direction == 'inbound'\n        && request.resource.data.fromEmail == authEmail()\n        && ownTenantDocById(request.resource.data.tenantId);\n    }\n\n    match /userProfiles/{userId} {\n      allow read, create, update: if isOwnProfile(userId);\n      allow read, update, delete: if isAdminFromAnotherProfile(userId);\n    }\n\n    match /people/{documentId} {\n      allow read, create, update, delete: if isAdmin();\n    }\n\n    match /properties/{documentId} {\n      allow read, create, update, delete: if isAdmin();\n    }\n\n    match /companies/{documentId} {\n      allow read, create, update, delete: if isAdmin();\n    }\n\n    match /tenants/{documentId} {\n      allow read, create, update, delete: if isAdmin();\n      allow read: if isTenant() && resource.data.email == authEmail();\n    }\n\n    match /messages/{documentId} {\n      allow read, create, update, delete: if isAdmin();\n      allow read: if isTenant() && tenantOwnsMessage(resource.data);\n      allow create: if tenantCanCreateMessage();\n    }\n\n    match /tickets/{documentId} {\n      allow read, create, update, delete: if isAdmin();\n      allow read: if isTenant() && ownTenantDocById(resource.data.tenantId);\n    }\n\n    match /ticketEvents/{documentId} {\n      allow read, create, update, delete: if isAdmin();\n    }\n\n    match /messageDrafts/{documentId} {\n      allow read, create, update, delete: if isAdmin();\n    }\n\n    match /documentTemplates/{documentId} {\n      allow read, create, update, delete: if isAdmin();\n    }\n\n    match /adminSettings/{documentId} {\n      allow read, create, update, delete: if isAdmin();\n    }\n\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-04-02T22:11:17.039615Z","metadata":{"services":["cloud.firestore"]}}
