rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwnProfile(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function adminProfilePath() {
      return /databases/$(database)/documents/userProfiles/$(request.auth.uid);
    }

    function isAdminFromAnotherProfile(targetUserId) {
      return signedIn()
        && request.auth.uid != targetUserId
        && exists(adminProfilePath())
        && get(adminProfilePath()).data.role == 'admin';
    }

    function isAdmin() {
      return signedIn()
        && exists(adminProfilePath())
        && get(adminProfilePath()).data.role == 'admin';
    }

    function isTenant() {
      return signedIn()
        && exists(adminProfilePath())
        && get(adminProfilePath()).data.role == 'tenant';
    }

    function authEmail() {
      return signedIn() && request.auth.token.email is string
        ? request.auth.token.email
        : '';
    }

    function ownTenantDocById(tenantId) {
      return tenantId is string
        && tenantId != ''
        && signedIn()
        && exists(/databases/$(database)/documents/tenants/$(tenantId))
        && get(/databases/$(database)/documents/tenants/$(tenantId)).data.email == authEmail();
    }

    function tenantOwnsMessage(data) {
      return signedIn()
        && (
          (data.tenantId is string && ownTenantDocById(data.tenantId))
          || (data.fromEmail is string && data.fromEmail == authEmail())
        );
    }

    function tenantCanCreateMessage() {
      return isTenant()
        && request.resource.data.channel == 'portal'
        && request.resource.data.direction == 'inbound'
        && request.resource.data.fromEmail == authEmail()
        && ownTenantDocById(request.resource.data.tenantId);
    }

    match /userProfiles/{userId} {
      allow read, create, update: if isOwnProfile(userId);
      allow read, update, delete: if isAdminFromAnotherProfile(userId);
    }

    match /people/{documentId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /properties/{documentId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /companies/{documentId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /tenants/{documentId} {
      allow read, create, update, delete: if isAdmin();
      allow read: if isTenant() && resource.data.email == authEmail();
    }

    match /messages/{documentId} {
      allow read, create, update, delete: if isAdmin();
      allow read: if isTenant() && tenantOwnsMessage(resource.data);
      allow create: if tenantCanCreateMessage();
    }

    match /tickets/{documentId} {
      allow read, create, update, delete: if isAdmin();
      allow read: if isTenant() && ownTenantDocById(resource.data.tenantId);
    }

    match /ticketEvents/{documentId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /messageEvents/{documentId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /messageDrafts/{documentId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /followUps/{documentId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /deletedMessages/{documentId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /documentTemplates/{documentId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /adminSettings/{documentId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
